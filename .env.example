# ── .env.example — LLM Council ───────────────────────────────────────────────
# Copier ce fichier en .env et renseigner les valeurs
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── OBLIGATOIRE ───────────────────────────────────────────────────────────────

# Clé API OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clé secrète JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=changez-moi-avant-tout-deploiement-production

# ── DONNÉES ───────────────────────────────────────────────────────────────────

# Chemin vers le dossier de données sur l'hôte (Windows : D:/llm-council-data)
DATA_PATH=D:/llm-council-data

# ── RÉSEAU ────────────────────────────────────────────────────────────────────

# Port d'accès au frontend (défaut : 80)
FRONTEND_PORT=80

# URL du backend (vue depuis le navigateur — pas depuis Docker)
# En local : http://localhost:8001
# En intranet : http://192.168.1.100:8001 ou http://ai.monentreprise.local:8001
VITE_API_BASE=http://localhost:8001

# Origines autorisées pour CORS (séparées par des virgules)
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://frontend

# ── QDRANT ────────────────────────────────────────────────────────────────────

# Nom de la collection RAG dans Qdrant
RAG_COLLECTION=llm_council_rag

# API Key Qdrant (laisser vide pour usage local, renseigner pour Qdrant Cloud)
QDRANT_API_KEY=

# ── PRODUCTION ────────────────────────────────────────────────────────────────

# Mettre à 1 pour activer les vérifications de sécurité strictes
# (JWT_SECRET obligatoire, pas de valeur par défaut)
PRODUCTION=0
